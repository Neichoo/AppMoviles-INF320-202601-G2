<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalculadoraPropina.MainPage"
             Title="Calculadora de Propina"
             BackgroundColor="Black">

    <Shell.TitleView>
        <Grid>
            <Label
                Text="Calculadora de Propina"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                VerticalOptions="Center"
                FontAttributes="Bold" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Border Stroke="Black" StrokeShape="RoundRectangle 5">
                <Grid
                    BackgroundColor="Gray"
                    Padding="20"
                    RowSpacing="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label
                        Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Text="Total por Persona"
                        Style="{StaticResource SubHeadline}" />

                    <Label
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        FontSize="18"
                        Text="Total por persona"
                        Style="{StaticResource SubHeadline}" />

                    <Label
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="0,28,0,0"
                        FontSize="32"
                        Text="{Binding TotalPorPersonaTexto}"
                        Style="{StaticResource SubHeadline}" />

                    <Grid
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        ColumnDefinitions="*,*"
                        ColumnSpacing="16"
                        Margin="0,12,0,0">

                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label
                                FontSize="15"
                                Text="Propina por persona"
                                Style="{StaticResource SubHeadline}" />

                            <Label
                                Text="{Binding PropinaPorPersonaTexto}"
                                Style="{StaticResource SubHeadline}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label
                                FontSize="15"
                                Text="Subtotal por persona"
                                Style="{StaticResource SubHeadline}" />

                            <Label
                                Text="{Binding SubtotalPorPersonaTexto}"
                                Style="{StaticResource SubHeadline}" />
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </Border>

            <Border Stroke="Black" StrokeShape="RoundRectangle 5">
                <Grid
                    BackgroundColor="Gray"
                    Padding="20"
                    RowSpacing="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        FontSize="15"
                        Text="Total de consumo:"
                        Style="{StaticResource SubHeadline}" />

                    <Entry
                        Grid.Row="0"
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        Keyboard="Numeric"
                        Placeholder="0"
                        Text="{Binding TotalConsumoTexto}" />

                    <Label
                        Grid.Row="1"
                        Grid.Column="0"
                        FontSize="15"
                        Text="Propina predefinida:"
                        Style="{StaticResource SubHeadline}" />

                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        Text="10%"
                        Command="{Binding SeleccionarPropinaCommand}"
                        CommandParameter="{x:Int32 10}"
                        HorizontalOptions="Center" />

                    <Button
                        Grid.Row="1"
                        Grid.Column="2"
                        Text="15%"
                        Command="{Binding SeleccionarPropinaCommand}"
                        CommandParameter="{x:Int32 15}"
                        HorizontalOptions="Center" />

                    <Button
                        Grid.Row="1"
                        Grid.Column="3"
                        Text="20%"
                        Command="{Binding SeleccionarPropinaCommand}"
                        CommandParameter="{x:Int32 20}"
                        HorizontalOptions="Center" />

                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        FontSize="15"
                        Text="Propina variable:"
                        Style="{StaticResource SubHeadline}" />

                    <Slider
                        Grid.Row="2"
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        Margin="5, 0, 0, 0"
                        VerticalOptions="Center"
                        Minimum="0"
                        Maximum="50"
                        Value="{Binding PorcentajePropina}"
                        ThumbColor="LightBlue"
                        MinimumTrackColor="DarkBlue"
                        MaximumTrackColor="DarkBlue" />

                    <Label
                        Grid.Row="3"
                        Grid.Column="0"
                        FontSize="15"
                        Text="Porcentaje actual:"
                        Style="{StaticResource SubHeadline}" />

                    <Label
                        Grid.Row="3"
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        Text="{Binding PorcentajePropinaTexto}"
                        Style="{StaticResource SubHeadline}" />

                    <Label
                        Grid.Row="4"
                        Grid.Column="0"
                        FontSize="15"
                        Text="Cantidad de personas:"
                        Style="{StaticResource SubHeadline}" />

                    <Button
                        Grid.Row="4"
                        Grid.Column="1"
                        FontSize="40"
                        Text="-"
                        Command="{Binding CambiarCantidadPersonasCommand}"
                        CommandParameter="{x:Int32 -1}"
                        HorizontalOptions="Center" />

                    <Label
                        Grid.Row="4"
                        Grid.Column="2"
                        FontSize="40"
                        Text="{Binding CantidadPersonasTexto}"
                        Style="{StaticResource SubHeadline}" />

                    <Button
                        Grid.Row="4"
                        Grid.Column="3"
                        FontSize="40"
                        Text="+"
                        Command="{Binding CambiarCantidadPersonasCommand}"
                        CommandParameter="{x:Int32 1}"
                        HorizontalOptions="Center" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
