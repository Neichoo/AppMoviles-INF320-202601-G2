<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:MiAppGastos.Converters"
             xmlns:viewmodels="clr-namespace:MiAppGastos.ViewModels"
             x:Class="MiAppGastos.Views.MainPage"
             Title="GASTOS">
    
    <ContentPage.Resources>
        <converters:AmountColorConverter x:Key="AmountColorConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Balance -->
        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="5">
            <Label Text="Balance" FontSize="14" TextColor="Gray"/>
            <Label Text="{Binding TotalBalance, StringFormat='{0:C}'}" FontSize="32" FontAttributes="Bold"/>
            <HorizontalStackLayout Spacing="30">
                <VerticalStackLayout>
                    <Label Text="Ingresos" FontSize="12" TextColor="Green"/>
                    <Label Text="{Binding TotalIngresos, StringFormat='{0:C}'}" TextColor="Green"/>
                </VerticalStackLayout>
                <VerticalStackLayout>
                    <Label Text="Egresos" FontSize="12" TextColor="Red"/>
                    <Label Text="{Binding TotalGastos, StringFormat='{0:C}'}" TextColor="Red"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Lista de Transacciones -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Transactions}" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <HorizontalStackLayout Padding="10" Spacing="10">
                        <Label Text="{Binding Description}" VerticalOptions="Center" FontSize="16"/>
                        <Label Text="{Binding Date, StringFormat='dd-MM-yyyy'}" VerticalOptions="Center" FontSize="12" TextColor="Gray"/>
                        <Label Text="{Binding Amount, StringFormat='{0:C}'}" 
                               VerticalOptions="Center" 
                               TextColor="{Binding Type, Converter={StaticResource AmountColorConverter}}"/>
                        <Button Text="X" 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=DeleteTransactionCommand}" 
                                CommandParameter="{Binding Id}" 
                                BackgroundColor="Red" 
                                TextColor="White" 
                                CornerRadius="5" 
                                Padding="5,2" />
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Botón flotante + -->
        <Button Grid.Row="2" 
                Text="+" 
                FontSize="30" 
                CornerRadius="30" 
                WidthRequest="60" 
                HeightRequest="60"
                HorizontalOptions="End" 
                VerticalOptions="End" 
                Margin="20"
                Command="{Binding GoToAddTransactionCommand}" 
                BackgroundColor="#512BD4" 
                TextColor="White" />
    </Grid>
</ContentPage>