<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiAppGastos.Views.AddTransactionPage"
             Title="Nueva Transacción">
    
    <VerticalStackLayout Padding="20" Spacing="15">
        <!-- Descripción -->
        <Label Text="Descripción" FontSize="14" />
        <Entry Text="{Binding Description}" Placeholder="Ej. Supermercado" />

        <!-- Monto -->
        <Label Text="Monto" FontSize="14" />
        <Entry Text="{Binding Amount}" Keyboard="Numeric" Placeholder="0.00" />

        <!-- Fecha -->
        <Label Text="Fecha" FontSize="14" />
        <DatePicker Date="{Binding Date}" />

        <!-- Tipo (Ingreso/Gasto) - usando lista fija -->
        <Label Text="Tipo" FontSize="14" />
        <Picker Title="Selecciona tipo"
                ItemsSource="{Binding TipoOptions}"
                SelectedIndex="{Binding SelectedTipoIndex}" />

        <!-- Botones -->
        <HorizontalStackLayout Spacing="10">
            <Button Text="Guardar" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource Green}" />
            <Button Text="Cancelar" Command="{Binding CancelCommand}" BackgroundColor="{StaticResource Red}" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>